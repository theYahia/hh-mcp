  "description": "MCP server for hh.ru jobs API — vacancy search, salary stats, employers, regions. Public endpoints, no auth required.",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "hh-mcp": "dist/index.js" },
  "files": ["dist"],
  "engines": { "node": ">=18.0.0" },
  "scripts": {
    "build": "tsc",
